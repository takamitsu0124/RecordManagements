{
  "name": "root",
  "version": "1.0.0",
  "scripts": {
    "dev:app": "npm run dev -w app",
    "build:app": "npm run build -w app",
    "build:functions": "npm run build -w @rm/functions",
    "deploy:app": "npm run build -w app && firebase use recordmanagements-756bf && firebase deploy --only hosting:app",
    "deploy:functions": "firebase deploy --only functions --project recordmanagements-756bf",
    "saoif:image-analysis:setup": "python3 scripts/saoif_image_analysis/env_tool.py ensure",
    "saoif:image-analysis:storage": "python3 scripts/saoif_image_analysis/env_tool.py run scripts/saoif_image_analysis/storage_uploader.py",
    "saoif:image-analysis:gemini": "python3 scripts/saoif_image_analysis/env_tool.py run scripts/saoif_image_analysis/gemini_skill_csv.py",
    "saoif:image-analysis:ability-gemini": "python3 scripts/saoif_image_analysis/env_tool.py run scripts/saoif_image_analysis/gemini_ability_csv.py",
    "saoif:image-analysis:ability-gemini-sample": "mkdir -p ./tmp && python3 scripts/saoif_image_analysis/env_tool.py run scripts/saoif_image_analysis/gemini_ability_csv.py --folder ./scripts/skill-master/source-images/ability --limit 5 --output ./tmp/saoif_abilities.sample.csv",
    "saoif:image-analysis:ability-storage": "mkdir -p ./tmp && python3 scripts/saoif_image_analysis/env_tool.py run scripts/saoif_image_analysis/storage_uploader.py --folder ./scripts/skill-master/source-images/ability > ./tmp/ability.storage.json",
    "saoif:image-analysis:ability-uploaded-gemini": "mkdir -p ./tmp && python3 scripts/saoif_image_analysis/env_tool.py run scripts/saoif_image_analysis/gemini_ability_csv.py --input-file ./tmp/ability.storage.json --model gemini-2.5-flash-lite --output ./tmp/saoif_abilities.csv",
    "saoif:image-analysis:ability-pipeline": "npm run saoif:image-analysis:ability-storage && npm run saoif:image-analysis:ability-uploaded-gemini",
    "saoif:image-analysis:axe-storage": "mkdir -p ./tmp && python3 scripts/saoif_image_analysis/env_tool.py run scripts/saoif_image_analysis/storage_uploader.py --folder ./scripts/skill-master/source-images/axe > ./tmp/axe.storage.json",
    "saoif:image-analysis:axe-gemini": "mkdir -p ./tmp && python3 scripts/saoif_image_analysis/env_tool.py run scripts/saoif_image_analysis/gemini_skill_csv.py --input-file ./tmp/axe.storage.json --model gemini-2.5-flash-lite --output ./tmp/saoif_skills.csv",
    "saoif:image-analysis:axe-pipeline": "npm run saoif:image-analysis:axe-storage && npm run saoif:image-analysis:axe-gemini",
    "skill-master:upload-images": "node ./scripts/skill-master/upload-images.mjs",
    "skill-master:ocr": "node ./scripts/skill-master/ocr-to-csv.mjs",
    "skill-master:annotate-regions": "python3 ./scripts/skill-master/annotate-ocr-regions.py",
    "skill-master:import": "node ./scripts/skill-master/import.mjs",
    "schema-migration:migrate": "node ./scripts/schema-migration/migrate.mjs",
    "check:img-lazy-loading": "node ./scripts/check-img-lazy-loading.mjs",
    "dev:vapp": "npm run dev -w vite-project",
    "build:vapp": "npm run build -w vite-project"
  },
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@rm/db": "^1.0.0",
    "@rm/types": "^1.0.0",
    "@rm/utils": "^1.0.0",
    "copy-anything": "^4.0.2"
  },
  "devDependencies": {
    "firebase-admin": "^13.8.0",
    "firebase-tools": "^15.14.0",
    "lerna": "^8.1.7",
    "sharp": "^0.35.3"
  }
}
