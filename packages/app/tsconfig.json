{
  "extends": "@quasar/app-webpack/tsconfig-preset",
  "compilerOptions": {
    "baseUrl": ".",
    "target": "es2022",
    "lib": ["es2022", "dom"]
  },
  "exclude": [
    "./dist",
    "./.quasar",
    "./node_modules",
    "./src-capacitor",
    "./src-cordova",
    "./quasar.config.*.temporary.compiled*"
  ],
  "paths": {
    "@rm/db": ["../types/src"],
    "@rm/types": ["../types/src"],
    "@rm/utils": ["../utils/src"]
  }
}
