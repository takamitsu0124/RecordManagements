rules_version = '2';

service cloud.firestore {
	match /databases/{database}/documents {
		/*
		 * Role and guild scope are resolved from the users collection first.
		 * Custom Claims are intentionally not used yet because the current app
		 * already manages role and guild state in Firestore.
		 */
		function isSignedIn() {
			return request.auth != null;
		}

		function authUid() {
			return request.auth.uid;
		}

		function usersPath(uid) {
			return /databases/$(database)/documents/users/$(uid);
		}

		function guildPath(guildId) {
			return /databases/$(database)/documents/guilds/$(guildId);
		}

		function hasUsersDoc(uid) {
			return exists(usersPath(uid));
		}

		function usersDoc(uid) {
			return get(usersPath(uid)).data;
		}

		function hasGuildDoc(guildId) {
			return exists(guildPath(guildId));
		}

		function guildDoc(guildId) {
			return get(guildPath(guildId)).data;
		}

		function currentUserRole() {
			return !isSignedIn()
				? null
				: hasUsersDoc(authUid())
					? usersDoc(authUid()).role
						: null;
		}

		function currentUserGuildId() {
			return !isSignedIn()
				? null
				: hasUsersDoc(authUid())
					? usersDoc(authUid()).guildId
						: null;
		}

		function isAdmin() {
			return isSignedIn() && currentUserRole() == 'admin';
		}

		function isGuildAdmin() {
			return isSignedIn() && currentUserRole() == 'guild_admin';
		}

		function isSelf(uid) {
			return isSignedIn() && authUid() == uid;
		}

		function isValidAppRole(role) {
			return role == 'admin' || role == 'guild_admin' || role == 'member';
		}

		function sameGuildId(guildId) {
			return isSignedIn() && guildId != null && guildId != '' && currentUserGuildId() == guildId;
		}

		function isGuildMember(guildId) {
			return hasGuildDoc(guildId) && guildDoc(guildId).guildMember[authUid()] != null;
		}

		function ownsCreatedGuild(guildId) {
			return hasGuildDoc(guildId) && guildDoc(guildId).createdBy == authUid();
		}

		function canReadGuild(guildId) {
			return isAdmin() || sameGuildId(guildId) || isGuildMember(guildId) || ownsCreatedGuild(guildId);
		}

		function canManageGuild(guildId) {
			return isAdmin() || (isGuildAdmin() && canReadGuild(guildId));
		}

		function isApprovedGuildMember(guildId) {
			return isSignedIn() && guildId != null && guildId != '' && hasGuildDoc(guildId) && guildDoc(guildId).guildMember[authUid()] != null;
		}

		function canReadGuildSchedule(guildId) {
			return isAdmin() || isApprovedGuildMember(guildId) || ownsCreatedGuild(guildId);
		}

		function canCreateOwnGuildSchedule(responseId) {
			return request.resource.data.id == responseId &&
				request.resource.data.userId == authUid() &&
				request.resource.data.guildId == currentUserGuildId() &&
				request.resource.data.guildId != '' &&
				canReadGuildSchedule(request.resource.data.guildId);
		}

		function canUpdateOwnGuildSchedule() {
			return resource.data.userId == authUid() &&
				request.resource.data.id == resource.data.id &&
				request.resource.data.userId == resource.data.userId &&
				request.resource.data.guildId == resource.data.guildId &&
				request.resource.data.diff(resource.data).affectedKeys().hasOnly(['entries', 'updatedAt', 'updatedBy']) &&
				canReadGuildSchedule(resource.data.guildId);
		}

		function isCurrentUsersGuildMember(uid) {
			return hasUsersDoc(uid) && currentUserGuildId() != null && usersDoc(uid).guildId == currentUserGuildId();
		}

		function preservesUserIdentity(uid) {
			return request.resource.data.uid == resource.data.uid &&
				request.resource.data.id == resource.data.id &&
				request.resource.data.email == resource.data.email;
		}

		function hasValidUserSituation(value) {
			return value == '現役' ||
				value == '隠居' ||
				value == '引退' ||
				value == '';
		}

		function hasValidAttendanceFeatureVisibilityStatus(value) {
			return value == null || value == 'visible' || value == 'hidden';
		}

		function hasValidOptionalTimestamp(value) {
			return value == null || value is timestamp;
		}

		function hasValidAppUserData(data, uid) {
			return data.uid == uid &&
				data.id == uid &&
				data.email is string &&
				data.displayName is string &&
				data.displayNameKana is string &&
				data.guildId is string &&
				data.affiliationNum is int &&
				data.affiliationNum >= 0 &&
				hasValidUserSituation(data.situation) &&
				hasValidOptionalTimestamp(data.affiliationDate) &&
				hasValidOptionalTimestamp(data.gameStartDateAt) &&
				hasValidOptionalTimestamp(data.birthDateAt) &&
				data.phone is string &&
				data.imageUrls is list &&
				(data.weaponProficiencyLevels == null || data.weaponProficiencyLevels is map) &&
				(data.weaponProficiencySkillProgress == null || data.weaponProficiencySkillProgress is map) &&
				hasValidAttendanceFeatureVisibilityStatus(data.attendanceFeatureVisibilityStatus) &&
				isValidAppRole(data.role);
		}

		function hasValidGuildCalendarEventData(data, eventId) {
			return data.id == eventId &&
				data.guildId is string &&
				data.guildId != '' &&
				data.title is string &&
				data.title.size() > 0 &&
				data.description is string &&
				data.location is string &&
				data.allDay is bool &&
				data.startAt is timestamp &&
				data.endAt is timestamp &&
				data.startAt < data.endAt &&
				data.createdAt is timestamp &&
				data.updatedAt is timestamp &&
				data.createdBy is string &&
				data.updatedBy is string;
		}

		function hasValidBannerMasterData(data, bannerId) {
			return data.id == bannerId &&
				data.isActive is bool &&
				hasValidOptionalTimestamp(data.startAt) &&
				hasValidOptionalTimestamp(data.endAt) &&
				data.imageUrl is string &&
				data.createdAt is timestamp &&
				data.updatedAt is timestamp &&
				data.createdBy is string &&
				data.updatedBy is string;
		}

		function preservesGuildCalendarEventIdentity() {
			return request.resource.data.id == resource.data.id &&
				request.resource.data.guildId == resource.data.guildId &&
				request.resource.data.createdAt == resource.data.createdAt &&
				request.resource.data.createdBy == resource.data.createdBy;
		}

		function attendanceEventPath(eventId) {
			return /databases/$(database)/documents/attendance_events/$(eventId);
		}

		function hasAttendanceEventDoc(eventId) {
			return exists(attendanceEventPath(eventId));
		}

		function attendanceEventDoc(eventId) {
			return get(attendanceEventPath(eventId)).data;
		}

		function hasValidAttendanceEventData(data, eventId) {
			return data.id == eventId &&
				data.publicToken == eventId &&
				data.ownerUid is string &&
				data.ownerUid != '' &&
				data.title is string &&
				data.title.size() > 0 &&
				data.description is string &&
				data.location is string &&
				data.candidates is list &&
				data.candidateSummaries is map &&
				data.responseCount is int &&
				data.responseCount >= 0 &&
				hasValidOptionalTimestamp(data.answerDeadlineAt) &&
				data.isClosed is bool &&
				data.isDeleted is bool &&
				data.createdAt is timestamp &&
				data.updatedAt is timestamp &&
				data.createdBy is string &&
				data.updatedBy is string;
		}

		function preservesAttendanceEventIdentity() {
			return request.resource.data.id == resource.data.id &&
				request.resource.data.publicToken == resource.data.publicToken &&
				request.resource.data.ownerUid == resource.data.ownerUid &&
				request.resource.data.createdAt == resource.data.createdAt &&
				request.resource.data.createdBy == resource.data.createdBy;
		}

		function canCreateAttendanceResponse(eventId) {
			return hasAttendanceEventDoc(eventId) &&
				attendanceEventDoc(eventId).isDeleted == false &&
				attendanceEventDoc(eventId).isClosed == false &&
				(
					attendanceEventDoc(eventId).answerDeadlineAt == null ||
					request.time <= attendanceEventDoc(eventId).answerDeadlineAt
				);
		}

		function hasValidAttendanceResponseData(data, responseId) {
			return data.id == responseId &&
				data.eventId is string &&
				data.eventId != '' &&
				data.displayName is string &&
				data.displayName.size() > 0 &&
				data.comment is string &&
				data.answers is map &&
				data.createdAt is timestamp &&
				data.updatedAt is timestamp &&
				data.createdBy is string &&
				data.updatedBy is string;
		}

		function canReadAttendanceResponse(eventId) {
			return isSignedIn() &&
				hasAttendanceEventDoc(eventId) &&
				attendanceEventDoc(eventId).ownerUid == authUid() &&
				attendanceEventDoc(eventId).isDeleted == false;
		}

		function canPublicRefreshAttendanceEventSummary() {
			return request.resource.data.id == resource.data.id &&
				request.resource.data.publicToken == resource.data.publicToken &&
				request.resource.data.ownerUid == resource.data.ownerUid &&
				request.resource.data.title == resource.data.title &&
				request.resource.data.description == resource.data.description &&
				request.resource.data.location == resource.data.location &&
				request.resource.data.candidates == resource.data.candidates &&
				request.resource.data.answerDeadlineAt == resource.data.answerDeadlineAt &&
				request.resource.data.isClosed == resource.data.isClosed &&
				request.resource.data.isDeleted == resource.data.isDeleted &&
				request.resource.data.createdAt == resource.data.createdAt &&
				request.resource.data.createdBy == resource.data.createdBy &&
				request.resource.data.responseCount == resource.data.responseCount + 1 &&
				request.resource.data.diff(resource.data).affectedKeys().hasOnly([
					'candidateSummaries',
					'responseCount',
					'updatedAt',
					'updatedBy'
				]) &&
				canCreateAttendanceResponse(resource.data.id);
		}

		function isGuildClaimForOwnCreatedGuild(uid) {
			let nextGuildId = request.resource.data.guildId;
			let nextRole = request.resource.data.role;

			return isSelf(uid) &&
				resource.data.guildId == '' &&
				nextGuildId != '' &&
				ownsCreatedGuild(nextGuildId) &&
				isGuildMember(nextGuildId) &&
				request.resource.data.uid == resource.data.uid &&
				request.resource.data.id == resource.data.id &&
				request.resource.data.email == resource.data.email &&
				request.resource.data.diff(resource.data).affectedKeys().hasOnly(['guildId', 'role', 'updatedAt', 'updatedBy']) &&
				(
					(resource.data.role == 'admin' && nextRole == 'admin') ||
					(resource.data.role == 'member' && nextRole == 'guild_admin')
				);
		}

		match /skill_master/{skillId} {
			allow read: if isSignedIn();
			allow create, update, delete: if isAdmin();
		}

		match /users/{uid} {
			allow read: if isSignedIn() && (
				isAdmin() ||
				isSelf(uid) ||
				(isGuildAdmin() && resource.data.guildId == currentUserGuildId())
			);

			allow create: if isAdmin() &&
				hasValidAppUserData(request.resource.data, uid);

			allow update: if isSignedIn() && (
				(
					isAdmin() &&
					preservesUserIdentity(uid) &&
					hasValidAppUserData(request.resource.data, uid)
				) ||
				(
					isSelf(uid) &&
					hasValidAppUserData(request.resource.data, uid) &&
					preservesUserIdentity(uid) &&
					request.resource.data.guildId == resource.data.guildId &&
					request.resource.data.role == resource.data.role &&
					request.resource.data.diff(resource.data).affectedKeys().hasOnly([
						'displayName',
						'displayNameKana',
						'affiliationDate',
						'affiliationNum',
						'situation',
						'gameStartDateAt',
						'phone',
						'birthDateAt',
						'imageUrls',
						'weaponProficiencyLevels',
						'weaponProficiencySkillProgress',
						'updatedAt',
						'updatedBy'
					])
				) ||
				isGuildClaimForOwnCreatedGuild(uid) ||
				(
					isGuildAdmin() &&
					hasValidAppUserData(request.resource.data, uid) &&
					resource.data.guildId == currentUserGuildId() &&
					resource.data.role != 'admin' &&
					preservesUserIdentity(uid) &&
					request.resource.data.guildId == resource.data.guildId &&
					request.resource.data.role != 'admin' &&
					request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'updatedAt', 'updatedBy'])
				) ||
				(
					isGuildAdmin() &&
					hasValidAppUserData(request.resource.data, uid) &&
					resource.data.guildId == currentUserGuildId() &&
					resource.data.role != 'admin' &&
					preservesUserIdentity(uid) &&
					request.resource.data.guildId == resource.data.guildId &&
					request.resource.data.role == resource.data.role &&
					request.resource.data.diff(resource.data).affectedKeys().hasOnly([
						'imageUrls',
						'weaponProficiencyLevels',
						'weaponProficiencySkillProgress',
						'updatedAt',
						'updatedBy'
					])
				)
			);

			allow delete: if isAdmin();
		}

		match /user_skills/{userId} {
			allow read: if isSignedIn() && (
				isAdmin() ||
				isSelf(userId) ||
				isCurrentUsersGuildMember(userId)
			);

			allow create, update: if isSignedIn() && request.resource.data.userId == userId && (
				isAdmin() ||
				isSelf(userId) ||
				(
					isGuildAdmin() &&
					isCurrentUsersGuildMember(userId)
				)
			);

			allow delete: if isSignedIn() && (
				isAdmin() ||
				isSelf(userId) ||
				(
					isGuildAdmin() &&
					isCurrentUsersGuildMember(userId)
				)
			);
		}

		match /user/{uid} {
			allow read: if isAdmin();
			allow create, update, delete: if false;
		}

		match /guilds/{guildId} {
			allow read: if isSignedIn() && canReadGuild(guildId);

			allow create: if isSignedIn() &&
				request.resource.data.createdBy == authUid() &&
				request.resource.data.guildMember.keys().hasOnly([authUid()]) &&
				request.resource.data.officialMembers == 1 &&
				(
					isAdmin() ||
					currentUserGuildId() == null ||
					currentUserGuildId() == ''
				);

			allow update: if isSignedIn() &&
				canManageGuild(guildId) &&
				request.resource.data.diff(resource.data).affectedKeys().hasOnly([
					'guildName',
					'guildNameKana',
					'guildFoundingDateAt',
					'situation',
					'guildIdInGame',
					'officialMembers',
					'guildMemo',
					'guildLogo',
					'guildMember',
					'updatedAt',
					'updatedBy'
				]);

			allow delete: if isAdmin();
		}

		match /guild_schedule_responses/{responseId} {
			allow read: if isSignedIn() && canReadGuildSchedule(resource.data.guildId);

			allow create: if isSignedIn() && canCreateOwnGuildSchedule(responseId);

			allow update: if isSignedIn() && canUpdateOwnGuildSchedule();

			allow delete: if isSignedIn() &&
				resource.data.userId == authUid() &&
				canReadGuildSchedule(resource.data.guildId);
		}

		match /guild_calendar_events/{eventId} {
			allow read: if isSignedIn() && canReadGuildSchedule(resource.data.guildId);

			allow create: if isSignedIn() &&
				canManageGuild(request.resource.data.guildId) &&
				request.resource.data.createdBy == authUid() &&
				request.resource.data.updatedBy == authUid() &&
				hasValidGuildCalendarEventData(request.resource.data, eventId);

			allow update: if isSignedIn() &&
				canManageGuild(resource.data.guildId) &&
				preservesGuildCalendarEventIdentity() &&
				request.resource.data.updatedBy == authUid() &&
				hasValidGuildCalendarEventData(request.resource.data, eventId) &&
				request.resource.data.diff(resource.data).affectedKeys().hasOnly([
					'title',
					'description',
					'location',
					'startAt',
					'endAt',
					'allDay',
					'updatedAt',
					'updatedBy'
				]);

			allow delete: if isSignedIn() && canManageGuild(resource.data.guildId);
		}

		match /banner_master/{bannerId} {
			allow read: if isSignedIn();

			allow create: if isAdmin() &&
				hasValidBannerMasterData(request.resource.data, bannerId);

			allow update: if isAdmin() &&
				hasValidBannerMasterData(request.resource.data, bannerId) &&
				request.resource.data.id == resource.data.id &&
				request.resource.data.createdAt == resource.data.createdAt &&
				request.resource.data.createdBy == resource.data.createdBy;

			allow delete: if isAdmin();
		}

		match /attendance_events/{eventId} {
			allow get: if resource.data.isDeleted == false || (
				isSignedIn() &&
				resource.data.ownerUid == authUid()
			);

			allow list: if isSignedIn() &&
				resource.data.ownerUid == authUid() &&
				resource.data.isDeleted == false;

			allow create: if isSignedIn() &&
				request.resource.data.ownerUid == authUid() &&
				hasValidAttendanceEventData(request.resource.data, eventId);

			allow update: if (
				isSignedIn() &&
				resource.data.ownerUid == authUid() &&
				preservesAttendanceEventIdentity() &&
				hasValidAttendanceEventData(request.resource.data, eventId) &&
				request.resource.data.diff(resource.data).affectedKeys().hasOnly([
					'title',
					'description',
					'location',
					'candidates',
					'candidateSummaries',
					'responseCount',
					'answerDeadlineAt',
					'isClosed',
					'isDeleted',
					'updatedAt',
					'updatedBy'
				])
			) || canPublicRefreshAttendanceEventSummary();

			allow delete: if false;
		}

		match /attendance_responses/{responseId} {
			allow get, list: if canReadAttendanceResponse(resource.data.eventId);

			allow create: if
				hasValidAttendanceResponseData(request.resource.data, responseId) &&
				canCreateAttendanceResponse(request.resource.data.eventId);

			allow update, delete: if false;
		}
	}
}
